#
# Linux/arm64 6.1.y Kernel Configuration
# For Amlogic S905L3B (E900V22E) with Android Support
#

# 基础配置（从 ophub 仓库获取）
# 先下载基础配置：
# wget https://github.com/ophub/kernel/raw/main/kernel-config/release/stable/config-6.1

# ============================================
# Android 支持配置（添加这些到配置文件末尾）
# ============================================

#
# Android 内存管理
#
CONFIG_ASHMEM=y
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ANDROID_LOW_MEMORY_KILLER=y
CONFIG_ANDROID_PARANOID_NETWORK=y
CONFIG_ANDROID_INTFS=y
CONFIG_ANDROID_BINDER_IPC_SELFTEST=y
CONFIG_ANDROID_LMKD=y
CONFIG_ANDROID_PMEM=y

#
# 必要的内核功能
#
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_MEMCG_KMEM=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_DEVKMEM=y

#
# 网络支持
#
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_NAT=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y

#
# 文件系统支持
#
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

#
# 其他必要选项
#
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_PROFILING=y
CONFIG_PERF_EVENTS=y
CONFIG_DEBUG_INFO=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y
